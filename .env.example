# ────────────────────────────────────────────────────────────────────────────
# iLoveExams Environment Variables — Copy to .env and fill in values
# NEVER commit the actual .env file to Git
# ────────────────────────────────────────────────────────────────────────────

# Server
PORT=8085
NODE_ENV=production   # Set to 'production' on your live server

# Session security — use a strong random string (min 32 chars)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_AT_LEAST_32_CHARS

# AES Decryption key for encrypted question files (must match encrypt_questions.js)
# Must be exactly 32 bytes / characters
DECRYPTION_KEY=CHANGE_ME_TO_YOUR_32_CHAR_KEY_HERE

# Admin email — this email gets access to /neet_pg_admin.html
ADMIN_EMAIL=youradmin@yourdomain.com

# Razorpay Payment Gateway (get from razorpay.com dashboard)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXX
